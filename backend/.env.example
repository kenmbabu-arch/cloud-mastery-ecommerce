
# Application
PORT=8080

# Prisma MySQL URL used by backend/prisma/schema.prisma
# Local development via Cloud SQL Auth Proxy (tcp:3306):
# MYSQL_PRISMA_URL="mysql://<DB_USER>:<DB_PASS>@127.0.0.1:3306/<DB_NAME>"
#
# Cloud Run with Cloud SQL unix socket mounted at /cloudsql:
# MYSQL_PRISMA_URL="mysql://<DB_USER>:<DB_PASS>@localhost:3306/<DB_NAME>?socket=/cloudsql/<PROJECT_ID>:<REGION>:<INSTANCE_NAME>"
# Example (local proxy):
# MYSQL_PRISMA_URL="mysql://cloud_mastery:cloud_mastery@127.0.0.1:3306/cloud_mastery_sample"
# Example (Cloud Run):
MYSQL_PRISMA_URL="mysql://cloud_mastery:cloud_mastery@localhost:3306/cloud_mastery_sample?socket=/cloudsql/eddie-ngugi-8b88:us-central1:cloud-mastery-db-v8"
MYSQL_PRISMA_URL=""

# Optional helper values for CI/CD templates and scripts
DB_USER=""
DB_PASS=""
DB_NAME=""
CLOUD_SQL_INSTANCE_CONNECTION_NAME="" # format: project:region:instance

# Optional MySQL table overrides (defaults shown)
MYSQL_FINANCE_TABLE="table_finance"
MYSQL_PARTS_TABLE="table_parts_catalog"

# Set to true only when Cloud SQL/MySQL should be connected during app boot.
PRISMA_CONNECT_ON_INIT="false"